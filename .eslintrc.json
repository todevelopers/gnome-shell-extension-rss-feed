{
  "env": {
    "es2022": true
  },
  "extends": "eslint:recommended",
  "globals": {
    "global": "readonly",
    "_": "readonly",
    "C_": "readonly",
    "N_": "readonly",
    "ngettext": "readonly",
    "TextDecoder": "readonly",
    "TextEncoder": "readonly",
    "console": "readonly"
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-var": "off",
    "prefer-const": "off",
    "no-unused-vars": ["warn", { "varsIgnorePattern": "^_", "argsIgnorePattern": "^_" }],
    "no-mixed-spaces-and-tabs": "off",
    "no-useless-escape": "off",
    "no-redeclare": "off"
  }
}
